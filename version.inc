# Included by CMakeLists, edited by the build script
# (the version numbers are generated by the build script from the git current label)

set(SLIC3R_APP_NAME "MeshForge")
set(SLIC3R_APP_KEY "MeshForge")

if(NOT DEFINED BBL_INTERNAL_TESTING)
set(BBL_INTERNAL_TESTING "0")
endif()
set(MESHFORGE_VERSION "2.4.0-dev")
string(REGEX MATCH "^([0-9]+)\\.([0-9]+)\\.([0-9]+)"
       MESHFORGE_VERSION_MATCH ${MESHFORGE_VERSION})
set(MESHFORGE_VERSION_MAJOR ${CMAKE_MATCH_1})
set(MESHFORGE_VERSION_MINOR ${CMAKE_MATCH_2})
set(MESHFORGE_VERSION_PATCH ${CMAKE_MATCH_3})

set(SLIC3R_VERSION "02.06.00.51")

if (NOT DEFINED MESHFORGE_UPDATER_SIG_KEY)
    set(MESHFORGE_UPDATER_SIG_KEY "" CACHE STRING "Base64url encoded updater signature key")
endif()
